HTTP2_DATA_FRAME = 0x0
HTTP2_GOAWAY_FRAME = 0x7
HTTP2_RST_STREAM_FRAME = 0x3
HTTP2_WINDOW_UPDATE_FRAME = 0x8
HTTP2_PING_FRAME = 0x6
HTTP2_CONTINUATION_FRAME = 0x9
HTTP2_FLAG_END_HEADERS = 0x4
HTTP2_FLAG_END_STREAM = 0x1
HTTP2_FLAG_ACK = 0x1

