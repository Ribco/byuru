# ============================================================================
# DYNAMIC SUBDOMAIN PROXY (v1.2.0)
# ============================================================================
# Routes subdomains to localhost ports automatically.
#
# EXAMPLE: 3001.yourdomain.com -> localhost:3001
#          8080.yourdomain.com -> localhost:8080
#
# CONFIGURATION:
#   server {
#       listen 3950;
#       server_name ~^(\d+)\.yourdomain\.com$;
#       dynamic_subdomain on;
#       dynamic_subdomain_domain yourdomain.com;
#       dynamic_subdomain_mapping /path/to/map.json;  # optional
#   }
#
# NAMED SUBDOMAINS (via JSON mapping):
#   {
#       "user1": 3001,
#       "user2": 3002,
#       "api": 8080
#   }
#   Then: user1.yourdomain.com -> localhost:3001
#
# CLOUDFLARE TUNNEL SETUP:
#   1. DNS: Add CNAME *.yourdomain.com -> yourdomain.com (Proxied)
#   2. Tunnel: Public Hostname *.yourdomain.com -> http://localhost:3950
# ============================================================================

