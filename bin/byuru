class Logger:
    def __init__(self, access_log=None, error_log=None):
        self.access_log_path = access_log
        self.error_log_path = error_log
        self.access_file = None
        self.error_file = None

    def open_logs(self):
        if self.access_log_path:
            os.makedirs(os.path.dirname(self.access_log_path), exist_ok=True)
            self.access_file = open(self.access_log_path, 'a')
        if self.error_log_path:
            os.makedirs(os.path.dirname(self.error_log_path), exist_ok=True)
            self.error_file = open(self.error_log_path, 'a')

    def close_logs(self):
        if self.access_file:
            self.access_file.close()
        if self.error_file:
            self.error_file.close()

    def access(self, client_ip, method, path, status, bytes_sent, user_agent='-', protocol='HTTP/1.1'):
        timestamp = datetime.now().strftime('%d/%b/%Y:%H:%M:%S %z')
        line = f'{client_ip} - - [{timestamp}] "{method} {path} {protocol}" {status} {bytes_sent} "-" "{user_agent}"\n'
        print(line.strip())
        if self.access_file:
            self.access_file.write(line)
            self.access_file.flush()

    def error(self, message):
        timestamp = datetime.now().strftime('%Y/%m/%d %H:%M:%S')
        line = f'[{timestamp}] [error] {message}\n'
        print(line.strip(), file=sys.stderr)
        if self.error_file:
            self.error_file.write(line)
            self.error_file.flush()

    def info(self, message):
        timestamp = datetime.now().strftime('%Y/%m/%d %H:%M:%S')
        line = f'[{timestamp}] [info] {message}\n'
        print(line.strip())

class RateLimiter:
    def __init__(self, rate=10, per=1, burst=20):
        self.rate = rate
        self.per = per
        self.burst = burst
        self.clients = {}
        self.lock = threading.Lock()

    def is_allowed(self, client_ip):
        with self.lock:
            now = time.time()
            if client_ip not in self.clients:
                self.clients[client_ip] = {'tokens': self.burst, 'last_update': now}
            client = self.clients[client_ip]
            elapsed = now - client['last_update']
            client['tokens'] = min(self.burst, client['tokens'] + elapsed * (self.rate / self.per))
            client['last_update'] = now
            if client['tokens'] >= 1:
                client['tokens'] -= 1
                return True
            return False

    def cleanup(self):
        with self.lock:
            now = time.time()
            stale = [ip for ip, data in self.clients.items() if now - data['last_update'] > 60]
            for ip in stale:
                del self.clients[ip]

class ConfigParser:
    def __init__(self, config_text):
        self.config_text = config_text
        self.tokens = self._tokenize()
        self.pos = 0
        self.config = {}

    def _tokenize(self):
        text = self.config_text
        tokens = []
        i = 0
        while i < len(text):
            if text[i].isspace():
                i += 1
                continue
            if text[i] == '#':
                while i < len(text) and text[i] != '\n':
                    i += 1
                continue
            if text[i] in '{};':
                tokens.append(text[i])
                i += 1
                continue
            if text[i] == '"':
                j = i + 1
                while j < len(text) and text[j] != '"':
                    j += 1
                tokens.append(text[i:j+1])
                i = j + 1
                continue
            j = i
            while j < len(text) and not text[j].isspace() and text[j] not in '{};#"':
                j += 1
            if j > i:
                tokens.append(text[i:j])
            i = j
        return tokens

    def parse(self):
        while self.pos < len(self.tokens):
            self._parse_statement(self.config)
        return self.config

    def _parse_statement(self, ctx):
        if self.pos >= len(self.tokens):
            return
        key = self._current()
        self.pos += 1
        if key in ('events', 'http', 'server', 'location'):
            name = None
            if self._current() != '{':
                name = self._current()
                self.pos += 1
            self._expect('{')
            block = {}
            while self._current() != '}':
                self._parse_statement(block)
            self._expect('}')
            if key not in ctx:
                ctx[key] = []
            ctx[key].append({'name': name, 'config': block})
        else:
            values = []
            while self.pos < len(self.tokens) and self._current() != ';':
                val = self._current()
                if val.startswith('"') and val.endswith('"'):
                    val = val[1:-1]
                values.append(val)
                self.pos += 1
            self._expect(';')
            ctx[key] = values

    def _current(self):
        if self.pos < len(self.tokens):
            return self.tokens[self.pos]
        return None

    def _expect(self, token):
        if self._current() != token:
            raise ValueError(f"Expected {token}, got {self._current()}")
        self.pos += 1
class ConfigFixer:
    """Auto-fix common byuru/nginx config syntax errors."""
    
    @staticmethod
    def fix(config_text):
        lines = config_text.split('\n')
        fixed_lines = []
        
        for raw_line in lines:
            line = raw_line
            stripped = line.strip()
            
            # Skip empty lines and comments
            if not stripped or stripped.startswith('#'):
                fixed_lines.append(raw_line)
                continue
            
            # Fix 1: Missing semicolon at end of simple directives
            if not stripped.endswith(';') and not stripped.endswith('{') and not stripped.endswith('}'):
                if '{' not in stripped and '}' not in stripped:
                    if not any(stripped.startswith(kw) for kw in ('events', 'http', 'server', 'location', 'upstream', 'if')):
                        line = line.rstrip() + ';'
            
            # Fix 2: Double semicolons
            line = line.replace(';;', ';')
            
            # Fix 3: Missing space between directive and value
            import re
            line = re.sub(r'([a-zA-Z_][a-zA-Z0-9_]*)(\d)', r'\1 \2', line)
            
            fixed_lines.append(line)
        
        config_fixed = '\n'.join(fixed_lines)
        
        # Fix 4: Auto-close unclosed braces at EOF
        open_count = config_fixed.count('{')
        close_count = config_fixed.count('}')
        if open_count > close_count:
            config_fixed += '\n' + ('}\n' * (open_count - close_count))
        
        # Fix 5: Remove extra closing braces
        while config_fixed.count('}') > config_fixed.count('{'):
            last_brace = config_fixed.rfind('}')
            if last_brace != -1:
                config_fixed = config_fixed[:last_brace] + config_fixed[last_brace+1:]
        
        # Fix 6: Normalize tabs
        config_fixed = config_fixed.replace('\t', '    ')
        
        # Fix 7: Wrap bare server blocks in http {} (only if no http block exists)
        has_http = False
        for line in config_fixed.split('\n'):
            stripped = line.strip()
            if stripped.startswith('http') and stripped.endswith('{'):
                has_http = True
                break
        if not has_http and 'server {' in config_fixed:
            config_fixed = 'http {\n' + config_fixed + '\n}'
        
        return config_fixed
class HTTPRequest:
    def __init__(self):
        self.method = ''
        self.path = ''
        self.version = ''
        self.headers = {}
        self.body = b''
        self.query_string = ''
        self.client_ip = ''

    @classmethod
    def parse(cls, data, client_ip):
        req = cls()
        req.client_ip = client_ip
        try:
            header_end = data.find(b'\r\n\r\n')
            if header_end == -1:
                header_end = data.find(b'\n\n')
                if header_end == -1:
                    return None
                header_data = data[:header_end].decode('utf-8', errors='replace')
                req.body = data[header_end + 2:]
            else:
                header_data = data[:header_end].decode('utf-8', errors='replace')
                req.body = data[header_end + 4:]
            lines = header_data.split('\r\n')
            if len(lines) == 1:
                lines = header_data.split('\n')
            request_line = lines[0]
            parts = request_line.split()
            if len(parts) >= 2:
                req.method = parts[0]
                req.path = parts[1]
                req.version = parts[2] if len(parts) > 2 else 'HTTP/1.1'
            if '?' in req.path:
                req.path, req.query_string = req.path.split('?', 1)
            for line in lines[1:]:
                if ':' in line:
                    key, value = line.split(':', 1)
                    req.headers[key.strip().lower()] = value.strip()
            return req
        except Exception:
            return None

class HTTPResponse:
    def __init__(self, status=200, body=b'', headers=None):
        self.status = status
        self.body = body
        self.headers = headers or {}
        self.headers.setdefault('Server', f'byuru/{__version__}')
        self.headers.setdefault('Date', datetime.utcnow().strftime('%a, %d %b %Y %H:%M:%S GMT'))

    def to_bytes(self):
        status_text = HTTP_STATUS.get(self.status, 'Unknown')
        lines = [f'HTTP/1.1 {self.status} {status_text}']
        for key, value in self.headers.items():
            lines.append(f'{key}: {value}')
        lines.append('')
        header = '\r\n'.join(lines).encode('utf-8')
        return header + b'\r\n' + self.body

    @classmethod
    def redirect(cls, location, status=302):
        return cls(status=status, headers={'Location': location})

    @classmethod
    def json(cls, data, status=200):
        body = json.dumps(data).encode('utf-8')
        headers = {'Content-Type': 'application/json', 'Content-Length': str(len(body))}
        return cls(status=status, body=body, headers=headers)

    @classmethod
    def text(cls, text, status=200, content_type='text/plain'):
        body = text.encode('utf-8')
        headers = {'Content-Type': content_type, 'Content-Length': str(len(body))}
        return cls(status=status, body=body, headers=headers)

    @classmethod
    def html(cls, html_text, status=200):
        return cls.text(html_text, status, 'text/html')

class StaticFileHandler:
    def __init__(self, root, index_files=None, autoindex=False):
        self.root = os.path.abspath(root)
        self.index_files = index_files or ['index.html', 'index.htm']
        self.autoindex = autoindex

    def handle(self, path):
        safe_path = urllib.parse.unquote(path)
        safe_path = os.path.normpath(safe_path)
        if safe_path.startswith('..'):
            return HTTPResponse(403, body=b'Forbidden')
        file_path = os.path.join(self.root, safe_path.lstrip('/'))
        file_path = os.path.abspath(file_path)
        if not file_path.startswith(self.root):
            return HTTPResponse(403, body=b'Forbidden')
        if os.path.isdir(file_path):
            for index in self.index_files:
                index_path = os.path.join(file_path, index)
                if os.path.isfile(index_path):
                    return self._serve_file(index_path)
            if self.autoindex:
                return self._autoindex(file_path, safe_path)
            return HTTPResponse(403, body=b'Forbidden')
        if os.path.isfile(file_path):
            return self._serve_file(file_path)
        return HTTPResponse(404, body=b'Not Found')

    def _serve_file(self, file_path):
        ext = os.path.splitext(file_path)[1].lower()
        content_type = MIME_TYPES.get(ext, 'application/octet-stream')
        try:
            with open(file_path, 'rb') as f:
                body = f.read()
            headers = {
                'Content-Type': content_type,
                'Content-Length': str(len(body)),
                'Last-Modified': datetime.fromtimestamp(os.path.getmtime(file_path)).strftime('%a, %d %b %Y %H:%M:%S GMT'),
            }
            import hashlib
            etag = hashlib.md5(body).hexdigest()[:16]
            headers['ETag'] = f'"{etag}"'
            return HTTPResponse(200, body=body, headers=headers)
        except Exception as e:
            return HTTPResponse(500, body=f'Error: {e}'.encode())

    def _autoindex(self, dir_path, url_path):
        try:
            entries = os.listdir(dir_path)
            entries.sort()
            html = f'<!DOCTYPE html><html><head><title>Index of {url_path}</title></head><body><h1>Index of {url_path}</h1><hr><pre>'
            if url_path != '/':
                html += '<a href="../">../</a>\n'
            for entry in entries:
                full_path = os.path.join(dir_path, entry)
                if os.path.isdir(full_path):
                    entry += '/'
                html += f'<a href="{entry}">{entry}</a>\n'
            html += '</pre><hr></body></html>'
            return HTTPResponse.html(html)
        except Exception:
            return HTTPResponse(403, body=b'Forbidden')

class ReverseProxy:
    def __init__(self, upstream, timeout=60):
        self.upstream = upstream
        self.timeout = timeout

    def handle(self, request):
        try:
            upstream_url = urllib.parse.urlparse(self.upstream)
            host = upstream_url.hostname or '127.0.0.1'
            port = upstream_url.port or 80
            proxy_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            proxy_socket.settimeout(self.timeout)
            proxy_socket.connect((host, port))
            proxy_path = request.path
            if request.query_string:
                proxy_path += '?' + request.query_string
            proxy_request = f"{request.method} {proxy_path} HTTP/1.1\r\n"
            for key, value in request.headers.items():
                if key.lower() not in ('host', 'connection'):
                    proxy_request += f"{key}: {value}\r\n"
            proxy_request += f"Host: {host}:{port}\r\n"
            proxy_request += f"X-Real-IP: {request.client_ip}\r\n"
            proxy_request += f"X-Forwarded-For: {request.client_ip}\r\n"
            proxy_request += "Connection: close\r\n\r\n"
            proxy_socket.sendall(proxy_request.encode())
            if request.body:
                proxy_socket.sendall(request.body)
            response_data = b''
            while True:
                try:
                    chunk = proxy_socket.recv(8192)
                    if not chunk:
                        break
                    response_data += chunk
                except socket.timeout:
                    break
            proxy_socket.close()
            if not response_data:
                return HTTPResponse(502, body=b'Bad Gateway')
            header_end = response_data.find(b'\r\n\r\n')
            if header_end == -1:
                header_end = response_data.find(b'\n\n')
            if header_end != -1:
                body = response_data[header_end + 4:]
            else:
                body = b''
            return HTTPResponse(200, body=body)
        except Exception as e:
            return HTTPResponse(502, body=f'Bad Gateway: {e}'.encode())



class DynamicSubdomainProxy:
    """
    Reverse proxy that extracts port from subdomain.
    Matches: 3001.example.com -> localhost:3001
    Also supports: user1.example.com -> localhost:PORT (via mapping file)
    Usage in config:
        dynamic_subdomain on;
        dynamic_subdomain_domain example.com;
        dynamic_subdomain_mapping /path/to/map.json;  # optional
    """
    def __init__(self, base_domain='example.com', timeout=60, mapping_file=None):
        self.base_domain = base_domain
        self.timeout = timeout
        self.mapping_file = mapping_file
        self.port_pattern = re.compile(r'^(\d+)\.' + re.escape(base_domain) + r'$')
        self.subdomain_pattern = re.compile(r'^([a-zA-Z0-9_-]+)\.' + re.escape(base_domain) + r'$')

    def _load_mapping(self):
        """Load subdomain->port mapping from JSON file if provided."""
        if self.mapping_file and os.path.isfile(self.mapping_file):
            try:
                with open(self.mapping_file, 'r') as f:
                    return json.load(f)
            except Exception:
                return {}
        return {}

    def extract_port(self, host):
        """Extract port number from subdomain like '3001.ph.quackify.qzz.io'"""
        # First try numeric subdomain (3001.ph.quackify.qzz.io -> port 3001)
        match = self.port_pattern.match(host)
        if match:
            port = int(match.group(1))
            if 1 <= port <= 65535:
                return port

        # Then try named subdomain via mapping file (user1.ph.quackify.qzz.io -> mapped port)
        mapping = self._load_mapping()
        match = self.subdomain_pattern.match(host)
        if match:
            subdomain = match.group(1)
            if subdomain in mapping:
                port = int(mapping[subdomain])
                if 1 <= port <= 65535:
                    return port

        return None

    def handle(self, request):
        host = request.headers.get('host', '')
        port = self.extract_port(host)

        if not port:
            return HTTPResponse(404, body=b'Not Found: Invalid subdomain format. Use PORT.ph.quackify.qzz.io or configure a mapping file.')

        upstream = f'http://127.0.0.1:{port}'
        proxy = ReverseProxy(upstream, self.timeout)
        return proxy.handle(request)

class LoadBalancer:
    ROUND_ROBIN = 'round_robin'
    LEAST_CONN = 'least_conn'
    IP_HASH = 'ip_hash'

    def __init__(self, upstreams, method=ROUND_ROBIN):
        self.upstreams = upstreams
        self.method = method
        self.current = 0
        self.connections = {u: 0 for u in upstreams}
        self.lock = threading.Lock()

    def get_backend(self, client_ip=None):
        with self.lock:
            if self.method == self.ROUND_ROBIN:
                backend = self.upstreams[self.current % len(self.upstreams)]
                self.current += 1
                return backend
            elif self.method == self.LEAST_CONN:
                backend = min(self.connections, key=self.connections.get)
                self.connections[backend] += 1
                return backend
            elif self.method == self.IP_HASH:
                import hashlib
                h = hashlib.md5(client_ip.encode()).hexdigest()
                idx = int(h, 16) % len(self.upstreams)
                return self.upstreams[idx]
            return self.upstreams[0]

    def release(self, backend):
        with self.lock:
            if backend in self.connections:
                self.connections[backend] = max(0, self.connections[backend] - 1)

class ServerBlock:
    def __init__(self, config, logger):
        self.config = config
        self.logger = logger
        self.listen_port = 3950
        self.server_names = []
        self.root = '/var/www/html'
        self.index_files = ['index.html', 'index.htm']
        self.locations = []
        self.error_pages = {}
        self.rate_limiter = None
        self.autoindex = False
        self.ssl_enabled = False
        self.ssl_cert = None
        self.ssl_key = None
        self.auto_ssl = False
        self.auto_ssl_email = None
        self.dynamic_subdomain = False
        self.dynamic_subdomain_domain = 'example.com'
        self.dynamic_subdomain_mapping = None
        self._parse_config()
    def _parse_config(self):
        cfg = self.config.get('config', {})
        if 'listen' in cfg:
            listen_vals = cfg['listen']
            for val in listen_vals:
                if val.isdigit():
                    self.listen_port = int(val)
                elif val == 'ssl':
                    self.ssl_enabled = True
        if 'server_name' in cfg:
            self.server_names = cfg['server_name']
        if 'root' in cfg:
            self.root = cfg['root'][0]
        if 'index' in cfg:
            self.index_files = cfg['index']
        if 'autoindex' in cfg:
            self.autoindex = cfg['autoindex'][0].lower() == 'on'
        if 'location' in cfg:
            for loc in cfg['location']:
                self.locations.append({'path': loc['name'], 'config': loc['config']})
        if 'ssl_certificate' in cfg:
            self.ssl_cert = cfg['ssl_certificate'][0]
        if 'ssl_certificate_key' in cfg:
            self.ssl_key = cfg['ssl_certificate_key'][0]
        if 'auto_ssl' in cfg:
            self.auto_ssl = cfg['auto_ssl'][0].lower() == 'on'
        if 'auto_ssl_email' in cfg:
            self.auto_ssl_email = cfg['auto_ssl_email'][0]
        # Dynamic subdomain proxy config
        if 'dynamic_subdomain' in cfg:
            self.dynamic_subdomain = cfg['dynamic_subdomain'][0].lower() == 'on'
        if 'dynamic_subdomain_domain' in cfg:
            self.dynamic_subdomain_domain = cfg['dynamic_subdomain_domain'][0]
        if 'dynamic_subdomain_mapping' in cfg:
            self.dynamic_subdomain_mapping = cfg['dynamic_subdomain_mapping'][0]
        if 'limit_req' in cfg or 'limit_req_zone' in cfg:
            self.rate_limiter = RateLimiter(rate=10, per=1, burst=20)

    def handle_request(self, request):
        if self.rate_limiter and not self.rate_limiter.is_allowed(request.client_ip):
            return HTTPResponse(429, body=b'Too Many Requests')

        # Dynamic subdomain proxy: PORT.ph.quackify.qzz.io -> localhost:PORT
        if self.dynamic_subdomain:
            host = request.headers.get('host', '')
            # Check if host matches our dynamic subdomain domain
            if self.dynamic_subdomain_domain in host:
                dynamic_proxy = DynamicSubdomainProxy(
                    base_domain=self.dynamic_subdomain_domain,
                    timeout=60,
                    mapping_file=self.dynamic_subdomain_mapping
                )
                return dynamic_proxy.handle(request)

        # Server name matching...
        
        # Location matching with nginx-style priority:
        # 1. Exact match (=)
        # 2. Preferential prefix (^~) - longest wins, no regex
        # 3. Longest prefix match
        # 4. Regex (~, ~*) - first match wins
        # 5. Fallback to longest prefix
        
        matched_loc = None
        longest_prefix = None
        longest_len = 0
        
        for loc in self.locations:
            path = loc['path']
            loc_cfg = loc['config']
            
            # Exact match (= /path)
            if path.startswith('= '):
                exact_path = path[2:]
                if request.path == exact_path:
                    matched_loc = loc
                    break  # highest priority, stop immediately
            
            # Preferential prefix (^~ /path)
            elif path.startswith('^~ '):
                prefix_path = path[3:].rstrip('/')
                if request.path.startswith(prefix_path):
                    prefix_len = len(prefix_path)
                    if prefix_len > longest_len:
                        longest_len = prefix_len
                        longest_prefix = loc
                        matched_loc = loc  # ^~ wins over regex
            
            # Regex (~ /pattern or ~* /pattern)
            elif path.startswith('~ ') or path.startswith('~* '):
                if matched_loc and not matched_loc['path'].startswith('^~ '):
                    # Only check regex if no ^~ matched
                    pattern = path[2:].strip() if path.startswith('~ ') else path[3:].strip()
                    flags = 0 if path.startswith('~ ') else re.IGNORECASE
                    if re.search(pattern, request.path, flags):
                        matched_loc = loc
                        break  # first regex match wins
            
            # Normal prefix match
            else:
                prefix_path = path.rstrip('/')
                if request.path.startswith(prefix_path):
                    prefix_len = len(prefix_path)
                    if prefix_len > longest_len:
                        longest_len = prefix_len
                        longest_prefix = loc
                        if not matched_loc:
                            matched_loc = loc
        
        # If no exact/regex matched, use longest prefix
        if not matched_loc and longest_prefix:
            matched_loc = longest_prefix
        
        if matched_loc:
            loc_cfg = matched_loc['config']
            path = matched_loc['path']
            if 'proxy_pass' in loc_cfg:
                proxy = ReverseProxy(loc_cfg['proxy_pass'][0])
                return proxy.handle(request)
            elif 'return' in loc_cfg:
                code = int(loc_cfg['return'][0])
                return HTTPResponse(status=code, body=b'')
            elif 'try_files' in loc_cfg:
                return self._try_files(request, loc_cfg['try_files'])
        
        # Fallback to static handler
        handler = StaticFileHandler(self.root, self.index_files, self.autoindex)
        return handler.handle(request.path)


    def _match_location(self, request_path, location_path):
        if location_path == '= /':
            return request_path == '/'
        if location_path.startswith('~ '):
            pattern = location_path[2:]
            return re.search(pattern, request_path) is not None
        if location_path.startswith('~* '):
            pattern = location_path[3:]
            return re.search(pattern, request_path, re.IGNORECASE) is not None
        return request_path.startswith(location_path.rstrip('/'))

    def _try_files(self, request, files):
        handler = StaticFileHandler(self.root, self.index_files)
        for f in files:
            if f == '=404':
                return HTTPResponse(404, body=b'Not Found')
            test_path = f.replace('$uri', request.path)
            result = handler.handle(test_path)
            if result.status != 404:
                return result
        return HTTPResponse(404, body=b'Not Found')


class HPACKDecoder:
    def __init__(self):
        self.dynamic_table = []
        self.max_table_size = 4096

    def decode(self, data):
        headers = {}
        i = 0
        while i < len(data):
            byte = data[i]
            if byte & 0x80:
                index = self._decode_integer(data, i, 7)
                i = index[1]
                name, value = self._get_from_table(index[0])
                headers[name] = value
            elif byte & 0xc0 == 0x40:
                index = self._decode_integer(data, i, 6)
                i = index[1]
                if index[0] == 0:
                    name_len = self._decode_integer(data, i, 7)
                    i = name_len[1]
                    name = data[i:i+name_len[0]].decode('utf-8', errors='replace')
                    i += name_len[0]
                else:
                    name, _ = self._get_from_table(index[0])
                value_len = self._decode_integer(data, i, 7)
                i = value_len[1]
                value = data[i:i+value_len[0]].decode('utf-8', errors='replace')
                i += value_len[0]
                headers[name] = value
                self._add_to_table(name, value)
            elif byte & 0xf0 == 0x00:
                index = self._decode_integer(data, i, 4)
                i = index[1]
                if index[0] == 0:
                    name_len = self._decode_integer(data, i, 7)
                    i = name_len[1]
                    name = data[i:i+name_len[0]].decode('utf-8', errors='replace')
                    i += name_len[0]
                else:
                    name, _ = self._get_from_table(index[0])
                value_len = self._decode_integer(data, i, 7)
                i = value_len[1]
                value = data[i:i+value_len[0]].decode('utf-8', errors='replace')
                i += value_len[0]
                headers[name] = value
            elif byte & 0xf0 == 0x10:
                index = self._decode_integer(data, i, 4)
                i = index[1]
                if index[0] == 0:
                    name_len = self._decode_integer(data, i, 7)
                    i = name_len[1]
                    name = data[i:i+name_len[0]].decode('utf-8', errors='replace')
                    i += name_len[0]
                else:
                    name, _ = self._get_from_table(index[0])
                value_len = self._decode_integer(data, i, 7)
                i = value_len[1]
                value = data[i:i+value_len[0]].decode('utf-8', errors='replace')
                i += value_len[0]
                headers[name] = value
            elif byte & 0xe0 == 0x20:
                size = self._decode_integer(data, i, 5)
                i = size[1]
                self.max_table_size = size[0]
                self._evict_table()
            else:
                i += 1
        return headers

    def _decode_integer(self, data, start, prefix_bits):
        mask = (1 << prefix_bits) - 1
        value = data[start] & mask
        if value < mask:
            return (value, start + 1)
        i = start + 1
        m = 0
        while i < len(data):
            byte = data[i]
            value += (byte & 0x7f) << m
            m += 7
            i += 1
            if not (byte & 0x80):
                break
        return (value, i)

    def _get_from_table(self, index):
        if index == 0:
            return ('', '')
        if index <= len(HPACK_STATIC_TABLE):
            return HPACK_STATIC_TABLE[index - 1]
        dyn_index = index - len(HPACK_STATIC_TABLE) - 1
        if 0 <= dyn_index < len(self.dynamic_table):
            return self.dynamic_table[dyn_index]
        return ('', '')

    def _add_to_table(self, name, value):
        self.dynamic_table.insert(0, (name, value))
        self._evict_table()

    def _evict_table(self):
        while self.dynamic_table:
            size = sum(len(n.encode('utf-8')) + len(v.encode('utf-8')) + 32 for n, v in self.dynamic_table)
            if size <= self.max_table_size:
                break
            self.dynamic_table.pop()


class HPACKEncoder:
    def __init__(self):
        self.dynamic_table = []
        self.max_table_size = 4096

    def encode(self, headers):
        result = bytearray()
        for name, value in headers.items():
            found_index = 0
            for i, (static_name, static_value) in enumerate(HPACK_STATIC_TABLE):
                if static_name.lower() == name.lower() and static_value == value:
                    found_index = i + 1
                    break
                elif static_name.lower() == name.lower() and not static_value:
                    found_index = i + 1

            if found_index > 0 and HPACK_STATIC_TABLE[found_index - 1][1] == value:
                result.extend(self._encode_integer(found_index, 7))
                result[0] |= 0x80
            elif found_index > 0:
                result.extend(self._encode_integer(found_index, 6))
                result[0] |= 0x40
                result.extend(self._encode_string(value))
                self._add_to_table(name, value)
            else:
                result.append(0x40)
                result.extend(self._encode_string(name))
                result.extend(self._encode_string(value))
                self._add_to_table(name, value)
        return bytes(result)

    def _encode_integer(self, value, prefix_bits):
        mask = (1 << prefix_bits) - 1
        if value < mask:
            return bytes([value])
        result = bytearray([mask])
        value -= mask
        while value >= 0x80:
            result.append((value & 0x7f) | 0x80)
            value >>= 7
        result.append(value)
        return bytes(result)

    def _encode_string(self, s):
        encoded = s.encode('utf-8')
        length = self._encode_integer(len(encoded), 7)
        return length + encoded

    def _add_to_table(self, name, value):
        self.dynamic_table.insert(0, (name, value))
        while self.dynamic_table:
            size = sum(len(n.encode('utf-8')) + len(v.encode('utf-8')) + 32 for n, v in self.dynamic_table)
            if size <= self.max_table_size:
                break
            self.dynamic_table.pop()


class HTTP2Connection:
    def __init__(self, sock, addr, server_block, logger):
        self.sock = sock
        self.addr = addr
        self.server_block = server_block
        self.logger = logger
        self.decoder = HPACKDecoder()
        self.encoder = HPACKEncoder()
        self.streams = {}
        self.next_stream_id = 2
        self.settings = {
            'header_table_size': 4096, 'enable_push': 0,
            'max_concurrent_streams': 100, 'initial_window_size': 65535,
            'max_frame_size': 16384, 'max_header_list_size': 8192,
        }
        self.client_settings = {}
        self.running = True

    def send_frame(self, frame_type, flags, stream_id, payload):
        length = len(payload)
        header = struct.pack('>I', length)[1:] + struct.pack('>BBI', frame_type, flags, stream_id & 0x7fffffff)
        self.sock.sendall(header + payload)

    def send_settings(self, ack=False):
        if ack:
            self.send_frame(HTTP2_SETTINGS_FRAME, HTTP2_FLAG_ACK, 0, b'')
        else:
            payload = b''
            payload += struct.pack('>HH', 1, self.settings['header_table_size'])
            payload += struct.pack('>HH', 2, self.settings['enable_push'])
            payload += struct.pack('>HH', 3, self.settings['max_concurrent_streams'])
            payload += struct.pack('>HH', 4, self.settings['initial_window_size'])
            payload += struct.pack('>HH', 5, self.settings['max_frame_size'])
            self.send_frame(HTTP2_SETTINGS_FRAME, 0, 0, payload)

    def send_headers(self, stream_id, status, headers=None):
        response_headers = [(':status', str(status))]
        if headers:
            for k, v in headers.items():
                response_headers.append((k.lower(), v))
        encoded = self.encoder.encode(response_headers)
        self.send_frame(HTTP2_HEADERS_FRAME, HTTP2_FLAG_END_HEADERS, stream_id, encoded)

    def send_data(self, stream_id, data, end_stream=True):
        flags = HTTP2_FLAG_END_STREAM if end_stream else 0
        max_size = self.settings['max_frame_size']
        while len(data) > max_size:
            chunk = data[:max_size]
            data = data[max_size:]
            self.send_frame(HTTP2_DATA_FRAME, 0, stream_id, chunk)
        self.send_frame(HTTP2_DATA_FRAME, flags, stream_id, data)

    def handle_stream(self, stream_id, headers, body=b''):
        try:
            method = headers.get(':method', 'GET')
            path = headers.get(':path', '/')
            request = HTTPRequest()
            request.method = method
            request.path = path.split('?')[0]
            request.query_string = path.split('?', 1)[1] if '?' in path else ''
            request.version = 'HTTP/2.0'
            request.client_ip = self.addr[0]
            request.body = body
            request.headers = {k: v for k, v in headers.items() if not k.startswith(':')}
            response = self.server_block.handle_request(request)
            self.send_headers(stream_id, response.status, response.headers)
            if response.body:
                self.send_data(stream_id, response.body, end_stream=True)
            else:
                self.send_data(stream_id, b'', end_stream=True)
            user_agent = request.headers.get('user-agent', '-')
            self.logger.access(request.client_ip, method, path, response.status,
                             len(response.body), user_agent, 'HTTP/2.0')
        except Exception as e:
            self.logger.error(f"HTTP/2 stream {stream_id} error: {e}")
            self.send_headers(stream_id, 500)
            self.send_data(stream_id, b'Internal Server Error', end_stream=True)

    def run(self):
        try:
            preface = b''
            while len(preface) < len(HTTP2_PREFACE):
                chunk = self.sock.recv(len(HTTP2_PREFACE) - len(preface))
                if not chunk:
                    return
                preface += chunk
            if preface != HTTP2_PREFACE:
                self.logger.error("Invalid HTTP/2 preface")
                return

            frame_header = b''
            while len(frame_header) < HTTP2_FRAME_HEADER_SIZE:
                chunk = self.sock.recv(HTTP2_FRAME_HEADER_SIZE - len(frame_header))
                if not chunk:
                    return
                frame_header += chunk

            length = struct.unpack('>I', b'\x00' + frame_header[:3])[0]
            frame_type = frame_header[3]
            flags = frame_header[4]
            stream_id = struct.unpack('>I', frame_header[5:9])[0] & 0x7fffffff
            payload = b''
            while len(payload) < length:
                chunk = self.sock.recv(length - len(payload))
                if not chunk:
                    return
                payload += chunk

            if frame_type == HTTP2_SETTINGS_FRAME:
                for i in range(0, len(payload), 6):
                    if i + 6 <= len(payload):
                        setting_id = struct.unpack('>H', payload[i:i+2])[0]
                        value = struct.unpack('>I', payload[i+2:i+6])[0]
                        self.client_settings[setting_id] = value

            self.send_settings()
            self.send_settings(ack=True)

            current_stream = None
            current_headers = None
            current_body = bytearray()

            while self.running:
                frame_header = b''
                while len(frame_header) < HTTP2_FRAME_HEADER_SIZE:
                    chunk = self.sock.recv(HTTP2_FRAME_HEADER_SIZE - len(frame_header))
                    if not chunk:
                        return
                    frame_header += chunk

                length = struct.unpack('>I', b'\x00' + frame_header[:3])[0]
                frame_type = frame_header[3]
                flags = frame_header[4]
                stream_id = struct.unpack('>I', frame_header[5:9])[0] & 0x7fffffff

                payload = b''
                while len(payload) < length:
                    chunk = self.sock.recv(length - len(payload))
                    if not chunk:
                        return
                    payload += chunk

                if frame_type == HTTP2_SETTINGS_FRAME:
                    if flags & HTTP2_FLAG_ACK:
                        pass
                    else:
                        for i in range(0, len(payload), 6):
                            if i + 6 <= len(payload):
                                setting_id = struct.unpack('>H', payload[i:i+2])[0]
                                value = struct.unpack('>I', payload[i+2:i+6])[0]
                                self.client_settings[setting_id] = value
                        self.send_settings(ack=True)

                elif frame_type == HTTP2_HEADERS_FRAME:
                    headers = self.decoder.decode(payload)
                    if flags & HTTP2_FLAG_END_HEADERS:
                        if flags & HTTP2_FLAG_END_STREAM:
                            self.handle_stream(stream_id, headers, b'')
                        else:
                            current_stream = stream_id
                            current_headers = headers
                            current_body = bytearray()
                    else:
                        current_stream = stream_id
                        current_headers = headers
                        current_body = bytearray()

                elif frame_type == HTTP2_CONTINUATION_FRAME:
                    if current_stream == stream_id:
                        more_headers = self.decoder.decode(payload)
                        current_headers.update(more_headers)
                        if flags & HTTP2_FLAG_END_HEADERS and flags & HTTP2_FLAG_END_STREAM:
                            self.handle_stream(stream_id, current_headers, b'')
                            current_stream = None

                elif frame_type == HTTP2_DATA_FRAME:
                    if current_stream == stream_id:
                        current_body.extend(payload)
                        if flags & HTTP2_FLAG_END_STREAM:
                            self.handle_stream(stream_id, current_headers, bytes(current_body))
                            current_stream = None

                elif frame_type == HTTP2_PING_FRAME:
                    self.send_frame(HTTP2_PING_FRAME, HTTP2_FLAG_ACK, 0, payload)

                elif frame_type == HTTP2_GOAWAY_FRAME:
                    self.running = False
                    break

                elif frame_type == HTTP2_RST_STREAM_FRAME:
                    if stream_id in self.streams:
                        del self.streams[stream_id]
        except Exception as e:
            self.logger.error(f"HTTP/2 connection error: {e}")
        finally:
            try:
                self.sock.close()
            except:
                pass




class DynamicPortRouter:
    """
    Listen on multiple ports and transparently proxy each to localhost:same_port.
    This bypasses Cloudflare entirely - users connect directly to your IP:PORT.

    Usage in config:
        dynamic_port_range 3000 3100;

    Or CLI:
        byuru --port-range 3000:3100
    """
    def __init__(self, start_port=3000, end_port=3100, logger=None):
        self.start_port = start_port
        self.end_port = end_port
        self.logger = logger or Logger()
        self.sockets = {}
        self.running = False
        self.threads = []

    def start(self):
        self.running = True
        self.logger.info(f"DynamicPortRouter binding ports {self.start_port}-{self.end_port}...")
        bound = 0
        failed = 0
        for port in range(self.start_port, self.end_port + 1):
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                sock.setblocking(False)
                sock.bind(('0.0.0.0', port))
                sock.listen(128)
                self.sockets[port] = sock
                bound += 1
            except PermissionError:
                failed += 1
            except OSError:
                failed += 1
        self.logger.info(f"[PortRouter] Bound {bound} ports, {failed} failed")

        # Use select() to handle all sockets in one thread
        t = threading.Thread(target=self._accept_loop, daemon=True)
        t.start()
        self.threads.append(t)

        try:
            while self.running:
                time.sleep(1)
        except KeyboardInterrupt:
            self.stop()

    def _accept_loop(self):
        while self.running and self.sockets:
            readable, _, _ = select.select(list(self.sockets.values()), [], [], 1.0)
            for sock in readable:
                try:
                    client_sock, client_addr = sock.accept()
                    listen_port = sock.getsockname()[1]
                    t = threading.Thread(target=self._proxy_connection, args=(client_sock, client_addr, listen_port), daemon=True)
                    t.start()
                except OSError:
                    pass

    def _proxy_connection(self, client_sock, client_addr, listen_port):
        backend_sock = None
        try:
            backend_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            backend_sock.settimeout(30)
            backend_sock.connect(('127.0.0.1', listen_port))

            def forward(src, dst):
                try:
                    while True:
                        data = src.recv(16384)
                        if not data:
                            break
                        dst.sendall(data)
                except (OSError, ConnectionResetError, BrokenPipeError):
                    pass
                finally:
                    try:
                        src.shutdown(socket.SHUT_RDWR)
                    except OSError:
                        pass

            t1 = threading.Thread(target=forward, args=(client_sock, backend_sock), daemon=True)
            t2 = threading.Thread(target=forward, args=(backend_sock, client_sock), daemon=True)
            t1.start()
            t2.start()
            t1.join()
            t2.join()
        except ConnectionRefusedError:
            self.logger.error(f"[PortRouter] localhost:{listen_port} refused connection")
            try:
                client_sock.sendall(b"HTTP/1.1 502 Bad Gateway\r\nContent-Length: 0\r\n\r\n")
            except:
                pass
        except Exception as e:
            self.logger.error(f"[PortRouter] Error proxying port {listen_port}: {e}")
        finally:
            try:
                client_sock.close()
            except:
                pass
            if backend_sock:
                try:
                    backend_sock.close()
                except:
                    pass

    def stop(self):
        self.running = False
        for port, sock in self.sockets.items():
            try:
                sock.close()
            except:
                pass
        self.sockets.clear()

class ByuruServer:
    def __init__(self, config_path=None, http2=False, tls=False):
        self.http2_enabled = http2
        self.tls_enabled = tls
        self.tls_cert = os.path.expanduser('~/.byuru/certs/byuru.crt')
        self.tls_key = os.path.expanduser('~/.byuru/certs/byuru.key')
        self.config_path = config_path
        self.config = {}
        self.servers = []
        self.logger = Logger()
        self.running = False
        self.server_socket = None
        self.worker_threads = []
        self.max_workers = 4
        self.bind_failed = False

    def load_config(self, config_text=None):
        raw_text = None
        if config_text:
            raw_text = config_text
        elif self.config_path and os.path.exists(self.config_path):
            with open(self.config_path, 'r') as f:
                raw_text = f.read()
        else:
            raw_text = DEFAULT_CONFIG
        
        # Pre-fix common issues before parsing
        raw_text = ConfigFixer.fix(raw_text)
        
        parser = ConfigParser(raw_text)
        try:
            self.config = parser.parse()
        except ValueError as e:
            self.logger.error(f"Config parse error: {e}")
            raise
        
        if 'worker_processes' in self.config:
            wp = self.config['worker_processes'][0]
            if wp == 'auto':
                self.max_workers = os.cpu_count() or 4
            else:
                self.max_workers = int(wp)
        if 'http' in self.config:
            http_cfg = self.config['http'][0]['config']
            access_log = http_cfg.get('access_log', ['/var/log/byuru/access.log'])[0]
            error_log = http_cfg.get('error_log', ['/var/log/byuru/error.log'])[0]
            self.logger = Logger(access_log, error_log)
            if 'server' in http_cfg:
                for srv in http_cfg['server']:
                    self.servers.append(ServerBlock(srv, self.logger))
        if not self.servers:
            self.servers.append(ServerBlock({'config': {}}, self.logger))
    def _auto_ssl(self, server_block):
        """Automatically issue SSL certificate via acme.sh"""
        if not server_block.server_names:
            self.logger.error("auto_ssl requires server_name")
            return False
        domain = server_block.server_names[0]
        
        # Check if acme.sh is available
        acme_sh = os.path.expanduser('~/.acme.sh/acme.sh')
        if not os.path.isfile(acme_sh):
            import shutil
            acme_sh = shutil.which('acme.sh') or ''
        if not acme_sh or not os.path.isfile(acme_sh):
            self.logger.error("auto_ssl requires acme.sh. Install: curl https://get.acme.sh | sh")
            return False
        
        # Set cert paths
        cert_dir = os.path.expanduser(f'~/.acme.sh/{domain}')
        cert_file = os.path.join(cert_dir, 'fullchain.cer')
        key_file = os.path.join(cert_dir, f'{domain}.key')
        
        # If certs already exist, use them and skip issuance
        if os.path.isfile(cert_file) and os.path.isfile(key_file):
            self.logger.info(f"auto_ssl: existing cert found for {domain}, skipping issuance")
            server_block.ssl_cert = cert_file
            server_block.ssl_key = key_file
            return True
        
        # Issue new cert
        self.logger.info(f"auto_ssl: issuing certificate for {domain}...")
        
        # Build acme.sh command
        cmd = [acme_sh, '--issue', '-d', domain, '--standalone', '--force']
        if server_block.auto_ssl_email:
            cmd.extend(['--email', server_block.auto_ssl_email])
        
        try:
            import subprocess
            result = subprocess.run(
                cmd, capture_output=True, text=True, timeout=120
            )
            if result.returncode != 0:
                self.logger.error(f"auto_ssl: acme.sh failed: {result.stderr[-500:]}")
                return False
            
            # Install cert to standard location
            install_cmd = [
                acme_sh, '--install-cert', '-d', domain,
                '--cert-file', cert_file,
                '--key-file', key_file,
                '--fullchain-file', os.path.join(cert_dir, 'fullchain.cer')
            ]
            subprocess.run(install_cmd, capture_output=True, timeout=30)
            
            if os.path.isfile(cert_file) and os.path.isfile(key_file):
                server_block.ssl_cert = cert_file
                server_block.ssl_key = key_file
                self.logger.info(f"auto_ssl: certificate issued for {domain}")
                return True
            else:
                self.logger.error(f"auto_ssl: cert files not found after issuance")
                return False
                
        except subprocess.TimeoutExpired:
            self.logger.error("auto_ssl: acme.sh timed out")
            return False
        except Exception as e:
            self.logger.error(f"auto_ssl: error issuing cert: {e}")
            return False
    def start(self):
        self.running = True
        self.logger.open_logs()
        protocol = "HTTP/2" if self.http2_enabled else "HTTP/1.1"
        self.logger.info(f"byuru/{__version__} starting with {protocol}...")

        def handle_signal(signum, frame):
            self.logger.info(f"Received signal {signum}, shutting down...")
            self.stop()
            sys.exit(0)

        signal.signal(signal.SIGTERM, handle_signal)
        signal.signal(signal.SIGINT, handle_signal)

        for server in self.servers:
            if server.auto_ssl and server.ssl_enabled:
                if not server.ssl_cert or not os.path.isfile(server.ssl_cert):
                    self._auto_ssl(server)
        for server in self.servers:
            self._start_server(server)
        if self.bind_failed:
            self.logger.error("byuru failed to start due to bind errors")
            self.stop()
            sys.exit(1)
        self.logger.info("byuru started successfully")
        try:
            while self.running:
                time.sleep(1)
        except KeyboardInterrupt:
            self.stop()

    def _start_server(self, server_block):
        port = server_block.listen_port
        use_ssl = self.tls_enabled or server_block.ssl_enabled
        cert_file = server_block.ssl_cert or self.tls_cert
        key_file = server_block.ssl_key or self.tls_key
        try:
            self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            if use_ssl:
                import ssl
                try:
                    context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
                    context.load_cert_chain(cert_file, key_file)
                except FileNotFoundError:
                    self.logger.error(f"TLS cert/key not found: {cert_file}, {key_file}")
                    self.logger.error("Run: byuructl tls")
                    self.bind_failed = True
                    return
                if self.http2_enabled:
                    context.set_alpn_protocols(['h2', 'http/1.1'])
                self.server_socket = context.wrap_socket(self.server_socket, server_side=True)
                protocol = "HTTPS" + ("+HTTP/2" if self.http2_enabled else "")
            else:
                protocol = "HTTP" + ("/2" if self.http2_enabled else "")
            self.server_socket.bind(('0.0.0.0', port))
            self.server_socket.listen(128)
            self.logger.info(f"Listening on 0.0.0.0:{port} ({protocol})")
            for i in range(self.max_workers):
                t = threading.Thread(target=self._worker, args=(server_block, i))
                t.daemon = True
                t.start()
                self.worker_threads.append(t)
        except Exception as e:
            self.logger.error(f"Failed to bind to port {port}: {e}")
            self.bind_failed = True
            return

    def _worker(self, server_block, worker_id):
        self.logger.info(f"Worker {worker_id} started")
        while self.running:
            try:
                if not self.server_socket:
                    break
                ready, _, _ = select.select([self.server_socket], [], [], 1.0)
                if not ready:
                    continue
                client_socket, client_addr = self.server_socket.accept()
                self._handle_client(client_socket, client_addr, server_block)
            except Exception as e:
                if self.running:
                    self.logger.error(f"Worker {worker_id} error: {e}")

    def _handle_client(self, client_socket, client_addr, server_block):
        try:
            client_socket.settimeout(30)
            
            # Check ALPN for HTTP/2 over TLS
            if self.tls_enabled and self.http2_enabled:
                alpn = client_socket.selected_alpn_protocol()
                if alpn == 'h2':
                    conn = HTTP2Connection(client_socket, client_addr, server_block, self.logger)
                    conn.run()
                    return
            
            # HTTP/2 h2c detection (cleartext)
            if self.http2_enabled and not self.tls_enabled:
                peek_data = client_socket.recv(24, socket.MSG_PEEK)
                if len(peek_data) >= 24 and peek_data == HTTP2_PREFACE:
                    client_socket.recv(24)
                    conn = HTTP2Connection(client_socket, client_addr, server_block, self.logger)
                    conn.run()
                    return
            
            # HTTP/1.1 handling
            data = b''
            while True:
                chunk = client_socket.recv(4096)
                if not chunk:
                    break
                data += chunk
                if b'\r\n\r\n' in data or b'\n\n' in data:
                    break
            if not data:
                client_socket.close()
                return

            if self.http2_enabled and not self.tls_enabled and b'Upgrade: h2c' in data:
                self._handle_http2_upgrade(client_socket, client_addr, server_block, data)
                return

            request = HTTPRequest.parse(data, client_addr[0])
            if not request:
                client_socket.close()
                return
            response = server_block.handle_request(request)
            user_agent = request.headers.get('user-agent', '-')
            self.logger.access(request.client_ip, request.method, request.path, response.status, len(response.body), user_agent)
            client_socket.sendall(response.to_bytes())
            client_socket.close()
        except Exception as e:
            import ssl
            if isinstance(e, ssl.SSLError) and "HTTP_REQUEST" in str(e):
                pass  # Plain HTTP on TLS port — silently drop
            else:
                self.logger.error(f"Client handler error: {e}")
            try:
                client_socket.close()
            except:
                pass

    def _handle_http2_upgrade(self, client_socket, client_addr, server_block, data):
        try:
            response = b"HTTP/1.1 101 Switching Protocols\r\n"
            response += b"Connection: Upgrade\r\n"
            response += b"Upgrade: h2c\r\n"
            response += b"\r\n"
            client_socket.sendall(response)

            conn = HTTP2Connection(client_socket, client_addr, server_block, self.logger)
            conn.send_settings()

            request = HTTPRequest.parse(data, client_addr[0])
            if request:
                headers = {
                    ':method': request.method,
                    ':path': request.path + (('?' + request.query_string) if request.query_string else ''),
                    ':scheme': 'http',
                    ':authority': request.headers.get('host', 'localhost'),
                }
                headers.update(request.headers)
                conn.handle_stream(1, headers, request.body)

            conn.run()
        except Exception as e:
            self.logger.error(f"HTTP/2 upgrade error: {e}")
            try:
                client_socket.close()
            except:
                pass

    def stop(self):
        self.running = False
        self.logger.info("Shutting down byuru...")
        if self.server_socket:
            try:
                self.server_socket.close()
            except Exception:
                pass
            self.server_socket = None
        for t in self.worker_threads:
            t.join(timeout=2)
        self.logger.close_logs()
        print("byuru stopped.")

def print_banner():
    print(r"""
    ___.                                 
    \_ |__    ___.__.  __ __  _______   __ __ 
     | __ \  <   |  | |  |  \ \_  __ \ |  |  \ 
     | \_\ \  \___  | |  |  /  |  | \/ |  |  / 
     |___  /  / ____| |____/   |__|    |____/  
         \/   \/                               
    byuru v1.2.1 - Lightweight HTTP Server & Reverse Proxy
    """)

def main():
    import argparse
    parser = argparse.ArgumentParser(description='byuru - Lightweight HTTP Server')
    parser.add_argument('-c', '--config', help='Path to configuration file')
    parser.add_argument('-p', '--port', type=int, default=3950, help='Port to listen on')
    parser.add_argument('-r', '--root', default='./www', help='Document root')
    parser.add_argument('-t', '--test', action='store_true', help='Test configuration')
    parser.add_argument('-v', '--version', action='version', version=f'byuru/{__version__}')
    parser.add_argument('--http2', action='store_true', help='Enable HTTP/2 support')
    parser.add_argument('--tls', action='store_true', help='Enable HTTPS/TLS')
    parser.add_argument('--subdomain', metavar='DOMAIN', help='Enable dynamic subdomain proxy for DOMAIN (e.g., ph.quackify.qzz.io)')
    parser.add_argument('--subdomain-map', metavar='FILE', help='JSON file for named subdomain->port mappings')
    parser.add_argument('--port-range', metavar='START:END', help='Enable dynamic port router (e.g., 3000:3100). Bypasses Cloudflare - users connect directly to IP:PORT')
    args = parser.parse_args()
    print_banner()
    server = ByuruServer(args.config, http2=args.http2, tls=args.tls)
    if args.test:
        print("Testing configuration...")
        server.load_config()
        print("Configuration test successful!")
        return
    if not args.config:
        # Build quick config with optional dynamic subdomain support
        subdomain_block = ""
        if args.subdomain:
            map_directive = f"dynamic_subdomain_mapping {args.subdomain_map};" if args.subdomain_map else "# dynamic_subdomain_mapping /path/to/map.json;"
            # Escape dots for regex
            escaped_domain = args.subdomain.replace('.', '\.')
            subdomain_block = f"""
            server {{
                listen {args.port};
                server_name ~^(\d+)\.{escaped_domain}$;
                dynamic_subdomain on;
                dynamic_subdomain_domain {args.subdomain};
                {map_directive}
                root {args.root};
                index index.html;
            }}"""

        quick_config = f"""
        http {{
            server {{
                listen {args.port};
                root {args.root};
                index index.html;
                location / {{
                    try_files $uri $uri/ =404;
                }}
            }}
            {subdomain_block}
        }}
        """
        os.makedirs(args.root, exist_ok=True)
        index_path = os.path.join(args.root, 'index.html')
        if not os.path.exists(index_path):
            with open(index_path, 'w') as f:
                f.write(f'<!DOCTYPE html><html><head><title>byuru</title><style>body{{font-family:sans-serif;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;margin:0;background:#1a1a2e;color:#fff}}h1{{font-size:3rem}}h1 span{{color:#00d4aa}}p{{color:#8892b0}}.footer{{position:fixed;bottom:2rem;left:0;right:0;text-align:center;color:#555;font-size:0.85rem}}</style></head><body><h1>by<span>uru</span></h1><p>Welcome to byuru!</p><p>byuru/{__version__}</p><div class="footer">Thank you for using byuru! Your HTTP server is running. However, further configurations are still needed.</div></body></html>')
    else:
        quick_config = None
    server.load_config(quick_config)

    # Start dynamic port router if --port-range is specified
    port_router = None
    if args.port_range:
        try:
            start, end = map(int, args.port_range.split(':'))
            port_router = DynamicPortRouter(start_port=start, end_port=end, logger=server.logger)
            router_thread = threading.Thread(target=port_router.start, daemon=True)
            router_thread.start()
            server.logger.info(f"Dynamic port router started: {start}-{end}")
        except ValueError:
            print("Error: --port-range must be in format START:END (e.g., 3000:3100)")
            sys.exit(1)

    server.start()

if __name__ == '__main__':
    main()
